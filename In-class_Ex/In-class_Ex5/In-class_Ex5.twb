          <datasource-dependencies datasource='federated.1up4y5h071bhfr19580as0ec5l4c'>
            <column caption='Pearson Correlation Coefficient' datatype='real' name='[Calculation_2615227063009280]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='CORR({INCLUDE [Order ID]:SUM([Sales])},{INCLUDE [Order ID (Orders1)]: SUM([Sales (Orders1)])})' />
            </column>
            <column caption='Boolean' datatype='boolean' name='[Calculation_2615227064586241]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='[Sub-Category] = [Sub-Category (Orders1)]' />
            </column>
            <column datatype='string' name='[Order ID (Orders1)]' role='dimension' type='nominal' />
            <column datatype='string' name='[Order ID]' role='dimension' type='nominal' />
            <column datatype='real' name='[Sales (Orders1)]' role='measure' type='quantitative' />
            <column datatype='real' name='[Sales]' role='measure' type='quantitative' />
            <column datatype='string' name='[Sub-Category (Orders1)]' role='dimension' type='nominal' />
            <column datatype='string' name='[Sub-Category]' role='dimension' type='nominal' />
            <column-instance column='[Calculation_2615227064586241]' derivation='None' name='[none:Calculation_2615227064586241:nk]' pivot='key' type='nominal' />
