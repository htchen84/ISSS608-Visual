      <column caption='Z-Score' datatype='real' name='[Calculation_2892576398069760]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='CASE [Parameters].[Parameter 1]&#13;&#10;when &quot;99%&quot; THEN 2.58&#13;&#10;WHEN &quot;95%&quot; THEN 1.96&#13;&#10;WHEN &quot;90%&quot; then 1.64&#13;&#10;END' />
      </column>
      <column caption='Marginal error' datatype='real' name='[Calculation_2892576399966210]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='MIN([Calculation_2892576398069760])*(STDEV([Proportion Reproducible])/SQRT(COUNT([respid])))' />
      </column>
      <column caption='Marginal Error Left' datatype='real' name='[Calculation_2892576402001923]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='AVG([Proportion Reproducible])-MIN([Calculation_2892576398069760])*(STDEV([Proportion Reproducible])/SQRT(COUNT([respid])))' />
