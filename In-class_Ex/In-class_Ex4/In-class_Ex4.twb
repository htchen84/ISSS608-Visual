      <column caption='Marginal Error Right' datatype='real' name='[Calculation_2892576402935812]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='AVG([Proportion Reproducible])+MIN([Calculation_2892576398069760])*(STDEV([Proportion Reproducible])/SQRT(COUNT([respid])))' />
      </column>
